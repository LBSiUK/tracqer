# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vinyl

# Password used to derive the AES-256 key.
# Change this before first run — all clients must use the same password.
PASSWORD=changeme

# Directory where uploaded photos are stored
PHOTOS_DIR=photos

# Bind address and port
HOST=0.0.0.0
PORT=8000
